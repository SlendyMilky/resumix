---
import type { SkillCategory } from "@/data/types";

interface Props {
  categories: SkillCategory[];
}

const { categories } = Astro.props;

const categoryConfig: Record<string, { icon: string; tagClass: string }> = {
  "Langages": {
    icon: "M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0l4.6-4.6-4.6-4.6L16 6l6 6-6 6-1.4-1.4z",
    tagClass: "tag-accent",
  },
  "Frontend": {
    icon: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5",
    tagClass: "",
  },
  "Backend": {
    icon: "M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01",
    tagClass: "tag-emerald",
  },
  "Base de données": {
    icon: "M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4",
    tagClass: "tag-amber",
  },
  "DevOps & Cloud": {
    icon: "M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z",
    tagClass: "tag-rose",
  },
  "Outils": {
    icon: "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z",
    tagClass: "tag-accent",
  },
};

const defaultConfig = {
  icon: "M13 10V3L4 14h7v7l9-11h-7z",
  tagClass: "",
};
---

<section aria-labelledby="skills-title">
  <h2 id="skills-title" class="section-title">Compétences</h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {categories.map((cat) => {
      const config = categoryConfig[cat.category] ?? defaultConfig;
      return (
        <div class="card group">
          <div class="flex items-center gap-3 mb-4">
            <div class="skill-icon">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d={config.icon} />
              </svg>
            </div>
            <h3 class="text-sm font-semibold uppercase tracking-wider text-surface-600 dark:text-surface-400">
              {cat.category}
            </h3>
          </div>
          <div class="flex flex-wrap gap-2">
            {cat.items.map((skill) => (
              <span class={`tag ${config.tagClass}`}>{skill}</span>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</section>
