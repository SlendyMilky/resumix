---
import type { Basics } from "@/data/types";

interface Props {
  basics: Basics;
}

const { basics } = Astro.props;

const initials = basics.name
  .replace(/[^\p{L}\s]/gu, "")
  .trim()
  .split(/\s+/)
  .map((w) => w[0])
  .join("")
  .slice(0, 2)
  .toUpperCase();

const networkIcons: Record<string, string> = {
  GitHub: "M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z",
  LinkedIn: "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z",
  Website: "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z",
};
---

<header class="hero">
  <div class="relative z-10 flex flex-col lg:flex-row items-center lg:items-start gap-8">
    <!-- Photo + identity -->
    <div class="flex flex-col items-center lg:items-start gap-5 shrink-0">
      <div class="profile-photo">
        {basics.photo ? (
          <img src={basics.photo} alt={`Photo de ${basics.name}`} width="144" height="144" loading="eager" />
        ) : (
          <div class="profile-photo-placeholder" aria-hidden="true">{initials}</div>
        )}
      </div>

      <div class="flex flex-wrap justify-center lg:justify-start gap-2">
        {basics.profiles.map((profile) => (
          <a
            href={profile.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-1.5 px-3.5 py-2 rounded-xl text-sm font-medium bg-white/60 text-surface-700 border border-surface-200/60 hover:border-primary-400/40 hover:bg-primary-50 hover:text-primary-700 hover:shadow-md hover:-translate-y-0.5 dark:bg-surface-800/60 dark:text-surface-300 dark:border-surface-700/50 dark:hover:bg-primary-900/30 dark:hover:text-primary-300 dark:hover:border-primary-500/30 transition-all duration-200"
            aria-label={`Profil ${profile.network}`}
          >
            {networkIcons[profile.network] && (
              <svg class="w-4 h-4 transition-transform duration-200 group-hover:scale-110" viewBox="0 0 24 24" fill="currentColor">
                <path d={networkIcons[profile.network]} />
              </svg>
            )}
            {profile.network}
          </a>
        ))}
      </div>
    </div>

    <!-- Name, title, contact, summary -->
    <div class="flex-1 text-center lg:text-left min-w-0">
      <h1 class="text-4xl lg:text-5xl font-bold text-surface-900 dark:text-white mb-2 tracking-tight">
        {basics.name}
      </h1>
      <p class="text-xl lg:text-2xl font-semibold mb-5 bg-gradient-to-r from-primary-600 to-accent-500 bg-clip-text text-transparent dark:from-primary-400 dark:to-accent-400">
        {basics.title}
      </p>

      <div class="flex flex-wrap justify-center lg:justify-start gap-x-5 gap-y-2 text-sm text-surface-600 dark:text-surface-400 mb-6">
        <a href={`mailto:${basics.email}`} class="flex items-center gap-1.5 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
          <svg class="w-4 h-4 text-primary-500/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          {basics.email}
        </a>

        {basics.phone && (
          <a href={`tel:${basics.phone.replace(/\s/g, "")}`} class="flex items-center gap-1.5 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
            <svg class="w-4 h-4 text-primary-500/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {basics.phone}
          </a>
        )}

        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-primary-500/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          {basics.location}
        </span>
      </div>

      <p class="text-surface-600 dark:text-surface-400 leading-relaxed max-w-3xl text-[0.95rem]">
        {basics.summary}
      </p>
    </div>
  </div>
</header>
