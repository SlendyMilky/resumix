---
import type { Education } from "@/data/types";

interface Props {
  items: Education[];
}

const { items } = Astro.props;
---

<section aria-labelledby="education-title">
  <h2 id="education-title" class="section-title">Formation</h2>

  <div class="space-y-4">
    {items.map((edu) => (
      <article class="card">
        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-2">
          <div>
            <h3 class="text-lg font-semibold text-surface-900 dark:text-white">
              {edu.institution}
            </h3>
            <p class="text-primary-600 dark:text-primary-400 font-medium">
              {edu.studyType} — {edu.area}
            </p>
          </div>
          <time
            class="text-sm text-surface-500 dark:text-surface-500 whitespace-nowrap font-mono"
            datetime={edu.startDate}
          >
            {edu.startDate} — {edu.endDate ?? "Présent"}
          </time>
        </div>

        {edu.score && (
          <p class="text-sm text-surface-600 dark:text-surface-400 mb-2">{edu.score}</p>
        )}

        {edu.highlights && edu.highlights.length > 0 && (
          <ul class="list-none space-y-1">
            {edu.highlights.map((h) => (
              <li class="flex items-start gap-2 text-sm text-surface-600 dark:text-surface-400">
                <span class="text-primary-500 mt-1 shrink-0">
                  <svg class="w-3 h-3" viewBox="0 0 12 12" fill="currentColor">
                    <circle cx="6" cy="6" r="2" />
                  </svg>
                </span>
                {h}
              </li>
            ))}
          </ul>
        )}
      </article>
    ))}
  </div>
</section>
