---
import type { Certification } from "@/data/types";

interface Props {
  items: Certification[];
}

const { items } = Astro.props;

function formatDate(date: string): string {
  const [year, month] = date.split("-");
  if (!month) return year;
  const months = ["Jan", "Fév", "Mar", "Avr", "Mai", "Juin", "Juil", "Août", "Sep", "Oct", "Nov", "Déc"];
  return `${months[parseInt(month) - 1]} ${year}`;
}
---

<section aria-labelledby="certifications-title">
  <h2 id="certifications-title" class="section-title">Certifications</h2>

  <div class="space-y-3">
    {items.map((cert) => (
      <article class="card flex items-center justify-between gap-4">
        <div>
          <h3 class="font-semibold text-surface-900 dark:text-white">
            {cert.url ? (
              <a href={cert.url} target="_blank" rel="noopener noreferrer" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
                {cert.name}
                <svg class="w-3 h-3 inline-block ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            ) : (
              cert.name
            )}
          </h3>
          <p class="text-sm text-surface-500 dark:text-surface-400">{cert.issuer}</p>
        </div>
        <time class="text-sm text-surface-500 dark:text-surface-500 whitespace-nowrap font-mono" datetime={cert.date}>
          {formatDate(cert.date)}
        </time>
      </article>
    ))}
  </div>
</section>
